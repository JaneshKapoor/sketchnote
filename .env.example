# Copy this file to ".env" and fill in real values. NEVER commit .env.
#
# These are INFRASTRUCTURE tokens only — used to DOWNLOAD and SELF-HOST our own
# open-weight models (Nemotron Parse, MiniCPM4.1-8B, optional SDXL-Turbo) on
# Modal serverless GPU and on the Hugging Face Space. They are NOT external model
# APIs and do not violate the hackathon "no proprietary hosted model API" rule.
#
# Do NOT add any other API key here. In particular DO NOT add an NVIDIA_API_KEY
# or any build.nvidia.com / NIM key — we self-host the Nemotron weights on Modal.

# Hugging Face — used to download open model weights / for the Space
HF_TOKEN=

# Modal — used to host OUR OWN open models on serverless GPU
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Optional: name of the deployed Modal app (defaults to "sketchnote")
# MODAL_APP_NAME=sketchnote
